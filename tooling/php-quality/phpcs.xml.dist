<?xml version="1.0"?>
<ruleset name="Hea-lth Portal Release Quality">
    <description>Release-blocking PHP compatibility and WordPress security checks for the portal source.</description>
    <file>../../plugin-src/hea-lth-platform-core</file>
    <file>../../theme-src/hea-lth-portal</file>
    <file>../../theme-src/hea-lth-portal-child</file>
    <exclude-pattern>*/assets/vendor/*</exclude-pattern>
    <arg name="basepath" value="../../"/>
    <arg name="colors"/>
    <arg value="ps"/>
    <rule ref="PHPCompatibilityWP"/>
    <rule ref="WordPress.Security"/>
    <rule ref="WordPress.DB.PreparedSQL"/>
    <config name="testVersion" value="7.4-"/>
    <config name="minimum_supported_wp_version" value="6.9"/>
</ruleset>
