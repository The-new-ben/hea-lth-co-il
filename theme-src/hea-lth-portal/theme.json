{
  "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": false,
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "custom": false,
      "customGradient": false,
      "palette": [
        {
          "slug": "forest-950",
          "color": "#0a2320",
          "name": "Forest 950"
        },
        {
          "slug": "forest-700",
          "color": "#235a51",
          "name": "Forest 700"
        },
        {
          "slug": "mint-50",
          "color": "#f2f9f6",
          "name": "Mint 50"
        },
        {
          "slug": "paper",
          "color": "#fffdf8",
          "name": "Paper"
        },
        {
          "slug": "bronze",
          "color": "#805a14",
          "name": "Bronze"
        },
        {
          "slug": "rust",
          "color": "#a74a37",
          "name": "Rust"
        }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1440px"
    },
    "spacing": {
      "customSpacingSize": false,
      "units": [
        "px",
        "rem",
        "%",
        "vw"
      ],
      "spacingSizes": [
        {
          "slug": "20",
          "size": "0.75rem",
          "name": "20"
        },
        {
          "slug": "30",
          "size": "1.25rem",
          "name": "30"
        },
        {
          "slug": "40",
          "size": "2rem",
          "name": "40"
        },
        {
          "slug": "50",
          "size": "3.5rem",
          "name": "50"
        },
        {
          "slug": "60",
          "size": "5.5rem",
          "name": "60"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "lineHeight": true,
      "letterSpacing": false,
      "fontFamilies": [
        {
          "fontFamily": "Noto Sans Hebrew, Heebo, Assistant, Arial, sans-serif",
          "slug": "ui",
          "name": "Hea-lth UI"
        },
        {
          "fontFamily": "Noto Serif Hebrew, Frank Ruhl Libre, Georgia, serif",
          "slug": "display",
          "name": "Hea-lth Display"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.875rem",
          "name": "Small"
        },
        {
          "slug": "base",
          "size": "1rem",
          "name": "Base"
        },
        {
          "slug": "large",
          "size": "1.5rem",
          "name": "Large"
        },
        {
          "slug": "xl",
          "size": "2.5rem",
          "name": "Extra large"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--mint-50)",
      "text": "var(--wp--preset--color--forest-950)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--ui)",
      "lineHeight": "1.7"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "500",
          "lineHeight": "1.02"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "500",
          "lineHeight": "1.08"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--forest-700)"
        }
      }
    }
  }
}
